# ── Application ──────────────────────────────────────────────────────────────
APP_PORT=8080
SPRING_PROFILES_ACTIVE=local

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fintech_ledger
POSTGRES_USER=fintech
POSTGRES_PASSWORD=changeme_local

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_local

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 64
JWT_SECRET=replace_with_256bit_hex_secret_never_commit_real_value
JWT_ACCESS_EXPIRY_MS=900000       # 15 min
JWT_REFRESH_EXPIRY_MS=604800000   # 7 days

# ── Idempotency ───────────────────────────────────────────────────────────────
IDEMPOTENCY_TTL_SECONDS=86400         # 24 h
IDEMPOTENCY_PROCESSING_TTL_SECONDS=30

# ── Outbox Scheduler ─────────────────────────────────────────────────────────
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_MAX_RETRIES=5
